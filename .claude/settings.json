{
  "alwaysThinkingEnabled": true,
  "disabledMcpServers": [
    "figma",
    "qdrant",
    "chroma",
    "n8n-mcp",
    "meta-ads",
    "facebook-ads-library",
    "mcp-memory-service",
    "sequential-thinking",
    "pexels"
  ],
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "WebFetch",
      "WebSearch"
    ],
    "deny": []
  },
  "preferredModel": "sonnet",
  "mcpServers": {
    "codebase-memory": {
      "type": "stdio",
      "command": "/Users/matsumototoshihiko/taisun_agent/tools/codebase-memory-mcp/codebase-memory-mcp",
      "args": [],
      "disabled": false,
      "defer_loading": true,
      "search_keywords": [
        "codegraph",
        "コードグラフ",
        "依存関係",
        "影響分析",
        "コード検索",
        "関数呼び出し",
        "code search",
        "dependency",
        "impact"
      ],
      "description": "CodeGraph - コードベース知識グラフ検索・影響分析（64言語対応）",
      "category": "code-intelligence"
    },
    "freee": {
      "command": "npx",
      "args": ["freee-mcp"],
      "disabled": false,
      "defer_loading": true,
      "description": "freee会計 - 仕訳・残高・請求書・人事労務をAIから操作"
    },
    "mfc_ca": {
      "url": "https://beta.mcp.developers.biz.moneyforward.com/mcp/ca/v3",
      "disabled": false,
      "defer_loading": true,
      "description": "マネーフォワード クラウド会計 - 仕訳・残高試算表・推移表をAIから操作"
    }
  },
  "maxParallelAgents": 5,
  "qualityGates": {
    "codeReviewMinScore": 80,
    "testCoverageMin": 80,
    "securityScanRequired": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/workflow-sessionstart-injector.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/codegraph-oss-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/model-auto-switch.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/skill-usage-guard.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agent-enforcement-guard.js",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/unified-guard.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/deviation-approval-guard.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write|Edit|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agent-enforcement-guard.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-compact-save.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/auto-adr.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/definition-lint-gate.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agent-trace-capture.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/compact-optimizer.js",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/task-overflow-guard.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agent-usage-logger.js",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/output-verifier.js",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/codegraph-roi-meter.js",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/codegraph-auto-index.js",
            "timeout": 12
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-handoff-generator.js",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop-failure-logger.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}